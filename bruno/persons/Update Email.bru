meta {
  name: Update Email
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/persons/me/email
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

docs {
  `password` confirms the *current* password (identity), not a new one. Requires the
  new `email` to differ from the current one and confirmation to match the stored
  hash, or a 401/422 domain error is returned.
}
