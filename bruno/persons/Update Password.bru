meta {
  name: Update Password
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/persons/me/password
  body: json
  auth: inherit
}

body:json {
  {
    "current_password": "{{password}}",
    "new_password": "{{new_password}}"
  }
}

docs {
  Rotates the password and ends every other live session — the one behind `{{token}}`
  in this environment stays valid. Re-run `Sign In` (with the new password) if you
  also want to refresh the stored token afterwards.
}
