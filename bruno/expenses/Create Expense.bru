meta {
  name: Create Expense
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/expenses
  body: json
  auth: inherit
}

body:json {
  {
    "amount_in_cents": 1500,
    "date": "2026-07-10",
    "description": "Almoço"
  }
}

docs {
  `date` and `description` are optional — an absent `date` defaults to today. The
  owner always comes from `{{token}}`'s actor, never the body.
}
