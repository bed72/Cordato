# Local database credentials, shared by docker-compose and the app.
# Copy this file to `.env` (git-ignored) and adjust as needed.
# Real environment variables always override these at runtime.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cordato
POSTGRES_USER=cordato
POSTGRES_PASSWORD=cordato

# Local Valkey (distributed cache) connection, shared by docker-compose and the app.
VALKEY_HOST=localhost
VALKEY_PORT=6379
